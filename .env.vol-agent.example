# .env.vol-agent.example — Environment variable template for the LLM Agent Framework
#
# Usage:
#   1. cp .env.vol-agent.example .env
#   2. Fill in your API keys
#   3. source .env && cargo run ...
#
# These env vars are read by: vol-llm-tui, vol-llm-ui-web, vol-llm-agent-channel,
# vol-llm-provider, vol-llm-tool (web search/fetch), and vol-llm-observability.

# =============================================
# LLM Provider API Keys
# =============================================

# Anthropic / DashScope proxy (primary)
ANTHROPIC_AUTH_TOKEN=""

# OpenAI API key (used by openai-compatible providers)
OPENAI_API_KEY=""

# DashScope embedding API (RAG / semantic search)
DASHSCOPE_API_KEY=""

# =============================================
# Built-in Tool API Keys
# =============================================

# Tavily web search API key
TAVILY_API_KEY=""

# =============================================
# Proxy Configuration (required in China)
# =============================================

# HTTP proxy for external API calls (Anthropic, OpenAI, web fetch, MCP http transports)
HTTPS_PROXY="http://192.168.2.98:8890"
HTTP_PROXY="http://192.168.2.98:8890"

# Bypass proxy for local and cluster addresses
NO_PROXY="localhost,127.0.0.1,192.168.0.0/16,10.0.0.0/8,.svc.cluster.local"

# =============================================
# Logging
# =============================================

RUST_LOG="info"
# RUST_LOG="vol_llm_agent=debug,vol_llm_agent_channel=trace"

# =============================================
# OpenTelemetry (agent observability)
# =============================================

# OTLP collector endpoint (logs, metrics, traces)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"

# Service identity in traces
OTEL_SERVICE_NAME="vol-agent"

# =============================================
# Web Fetch (built-in tool defaults)
# =============================================

# Maximum content length in bytes for web_fetch tool
# WEB_FETCH_MAX_LENGTH=1048576

# =============================================
# Deribit (if agent needs market data access)
# =============================================

# DERIBIT_CLIENT_ID=""
# DERIBIT_CLIENT_SECRET=""
