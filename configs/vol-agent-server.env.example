# vol-agent-server.env.example — Environment variables for the Agent Server
#
# Usage:
#   1. cp configs/vol-agent-server.env.example .env
#   2. Fill in your API keys
#   3. source .env && make web-backend
#
# Read by: vol-agent-server, vol-llm-provider, vol-llm-tool (web search/fetch)

# =============================================================================
# LLM Provider API Keys
# =============================================================================

# Anthropic / DashScope proxy (primary)
ANTHROPIC_AUTH_TOKEN=""

# OpenAI-compatible providers
OPENAI_API_KEY=""

# DashScope embedding API (RAG / semantic search)
DASHSCOPE_API_KEY=""

# =============================================================================
# Built-in Tool API Keys
# =============================================================================

# Tavily web search API key
TAVILY_API_KEY=""

# =============================================================================
# Proxy Configuration (required in China)
# =============================================================================

HTTPS_PROXY="http://192.168.2.98:8890"
HTTP_PROXY="http://192.168.2.98:8890"
NO_PROXY="localhost,127.0.0.1,192.168.0.0/16,10.0.0.0/8,.svc.cluster.local"

# =============================================================================
# Logging
# =============================================================================

RUST_LOG="info"
# RUST_LOG="vol_llm_agent=debug,vol_llm_agent_protocol=trace"

# =============================================================================
# OpenTelemetry (agent observability)
# =============================================================================

# OTLP collector endpoint (logs, metrics, traces)
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
# OTEL_SERVICE_NAME="vol-agent"
