# Stage 1: Build
FROM rust:latest AS builder

WORKDIR /app

# Copy dependency definitions first for better caching
COPY Cargo.toml Cargo.lock ./
COPY crates/ ./crates/
COPY .cargo ./.cargo

# Build release binary
RUN cargo build --release -vv -p vol-agent-manager

# Stage 2: Runtime
FROM debian:bookworm-slim

# Install CA certificates for HTTPS using Aliyun mirror
RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources && \
    apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

# Copy the binary from builder
COPY --from=builder /app/target/release/vol-agent-manager /usr/local/bin/vol-agent-manager

# Copy default config
COPY crates/vol-agent-manager/config.toml /app/config.toml

WORKDIR /app

ENTRYPOINT ["/usr/local/bin/vol-agent-manager"]
