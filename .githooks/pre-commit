#!/usr/bin/env bash
set -euo pipefail

# ── Colors ───────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# ── Staged files ─────────────────────────────────────────────────────────
STAGED_RUST=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)

# ── Nothing to check ─────────────────────────────────────────────────────
if [ -z "$STAGED_ALL" ]; then
  exit 0
fi

HAS_ERROR=0

# ── Rust checks ──────────────────────────────────────────────────────────
if [ -n "$STAGED_RUST" ]; then
  echo -e "${YELLOW}→ cargo fmt --all -- --check${NC}"
  if ! cargo fmt --all -- --check 2>/dev/null; then
    echo -e "${RED}✗ cargo fmt failed — run 'cargo fmt --all' to fix${NC}"
    HAS_ERROR=1
  else
    echo -e "${GREEN}✓ cargo fmt${NC}"
  fi

  echo -e "${YELLOW}→ cargo clippy --workspace${NC}"
  if ! cargo clippy --workspace 2>&1; then
    echo -e "${RED}✗ cargo clippy failed — fix the warnings above${NC}"
    HAS_ERROR=1
  else
    echo -e "${GREEN}✓ cargo clippy${NC}"
  fi

  # Also check test compilation (unit + integration, catches deny-level lint errors)
  echo -e "${YELLOW}→ cargo test --lib --tests --no-run${NC}"
  if ! cargo test --workspace --lib --tests --no-run 2>&1; then
    echo -e "${RED}✗ test compilation failed — see errors above${NC}"
    HAS_ERROR=1
  else
    echo -e "${GREEN}✓ test compiles${NC}"
  fi

  # Determine which crates have staged changes to focus coverage on
  CHANGED_CRATES=()
  for crate_dir in crates/*/; do
    crate=$(basename "$crate_dir")
    if echo "$STAGED_RUST" | grep -q "^crates/${crate}/"; then
      CHANGED_CRATES+=("$crate")
    fi
  done

  if [ ${#CHANGED_CRATES[@]} -gt 0 ] && [ -x ./scripts/check-coverage.sh ]; then
    echo -e "${YELLOW}→ rust: coverage check for changed crates: ${CHANGED_CRATES[*]}${NC}"
    if ! ./scripts/check-coverage.sh "${CHANGED_CRATES[@]}" 2>&1; then
      echo -e "${RED}✗ coverage check failed — see details above${NC}"
      HAS_ERROR=1
    else
      echo -e "${GREEN}✓ coverage${NC}"
    fi
  fi
fi

# ── Result ───────────────────────────────────────────────────────────────
if [ $HAS_ERROR -eq 1 ]; then
  echo -e "\n${RED}Commit blocked — fix the issues above and try again${NC}"
  exit 1
fi

echo -e "\n${GREEN}All checks passed ✓${NC}"
exit 0
