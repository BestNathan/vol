# .env.example - Environment variable template for vol-monitor
# 环境变量模板
#
# Usage:
#   1. Copy this file to .env
#   2. Fill in actual values
#   3. Run: source .env && cargo run --release
#
# IMPORTANT: Never commit .env file to git!

# =============================================
# Deribit API Credentials
# =============================================
DERIBIT_CLIENT_ID="your-deribit-client-id"
DERIBIT_CLIENT_SECRET="your-deribit-client-secret"
DERIBIT_WS_URL="wss://www.deribit.com/ws/api/v2"

# =============================================
# Feishu/Lark Credentials
# =============================================
FEISHU_APP_ID="your-feishu-app-id"
FEISHU_APP_SECRET="your-feishu-app-secret"
FEISHU_RECEIVE_ID="your-feishu-receive-id"

# =============================================
# Proxy Configuration (required in China)
# =============================================
HTTPS_PROXY="http://your-proxy-host:your-proxy-port"
HTTP_PROXY="http://your-proxy-host:your-proxy-port"

# =============================================
# Logging Configuration
# =============================================
RUST_LOG="info"
# RUST_LOG="vol_monitor=debug,tokio=trace"

# =============================================
# OpenTelemetry/Jaeger Configuration
# =============================================
OTEL_ENDPOINT="http://localhost:4317"
OTEL_SERVICE_NAME="vol-monitor-dev"
OTEL_SERVICE_NAMESPACE="deribit-dev"
OTEL_DEPLOYMENT_ENVIRONMENT="development"
OTEL_SAMPLE_RATE="1.0"

# =============================================
# Application Configuration
# =============================================
# Config file to use (relative to project root or absolute path)
VOL_MONITOR_CONFIG="./config.dev.toml"
# Or for production config:
# VOL_MONITOR_CONFIG="./config.prod.toml"
