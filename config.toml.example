# config.toml for vol-monitor

# =============================================================================
# Data Sources — enable/disable plugins, configure per-source
# =============================================================================
[data_sources]
enabled = ["deribit"]

[data_sources.deribit]
ws_url = "wss://www.deribit.com/ws/api/v2"
symbols = ["BTC", "ETH"]
poll_interval_secs = 60

# =============================================================================
# Tenor Definitions — bucket by DTE
# =============================================================================
[tenors]
short_max_dte = 7
medium_min_dte = 20
medium_max_dte = 40
long_min_dte = 80

# =============================================================================
# Alert Handlers — enable/disable plugins, configure thresholds
# =============================================================================
[alerts]
enabled = ["absolute_iv", "rate_change", "term_structure", "skew"]
cooldown_secs = 300

[alerts.absolute_iv]
short_threshold = 0.80
medium_threshold = 0.70
long_threshold = 0.60

[alerts.rate_of_change]
window_1h_threshold = 0.05
window_4h_threshold = 0.10
window_24h_threshold = 0.20

[alerts.term_structure]
short_long_spread_threshold = 0.15

[alerts.skew]
threshold = 0.10

# =============================================================================
# Notification Handlers — enable/disable plugins, configure per-destination
# =============================================================================
[notifications]
enabled = ["stdout"]

[notifications.feishu]
webhook_url = "https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_CODE"
hmac_secret = ""
message_template = "🚨 {tenor} {alert_type}: {value}"

# =============================================================================
# State Persistence
# =============================================================================
[state]
path = "~/.deribit-vol-monitor/state.json"
